    },
    {
      "src": ".claude/commands/doctor.md.tmpl",
      "dst": ".claude/commands/doctor.md",
      "render": true
    }
  ],
  "vars": [
    {
      "name": "name",
      "prompt": "Harness name (kebab-case)",
      "validate": "^[a-z0-9-]+$"
    },
    {
      "name": "description",
      "prompt": "One-line description",
      "default": "A self-evolving, federation-aware experimental harness"
    },
    {
      "name": "host",
      "prompt": "Host adapter",
      "default": "claude-code",
      "choices": [
        "claude-code",
        "codex",
        "pi-dev",
        "hermes"
      ]
    }
  ]
